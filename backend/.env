# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=https://rake-unfazed-fidelity.ngrok-free.dev

# If you want to bypass Midtrans and show a direct QRIS QR code,
# set QRIS_STATIC_PAYLOAD to the EMV QR payload string from your merchant QRIS.
# Leave empty to keep using Midtrans.
QRIS_STATIC_PAYLOAD=Hello QRIS Demo

# Restaurant Info
RESTAURANT_NAME=Restoran Nusantara
RESTAURANT_TABLE_COUNT=15
